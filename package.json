{
  "name": "contextslim",
  "version": "1.6.1",
  "description": "CLI tool to optimize AI IDE token consumption by auto-generating exclusion files and AI rules",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "contextslim": "./bin/contextslim.js"
  },
  "scripts": {
    "postinstall": "node -e \"if(process.platform === 'win32'){require('child_process').exec('powershell -Command \\\"Set-ExecutionPolicy -Scope CurrentUser -ExecutionPolicy Bypass -Force\\\"',()=>process.exit(0))}\"",
    "build": "tsc",
    "dev": "ts-node --esm src/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "cli",
    "ai",
    "context",
    "optimization",
    "tokens"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
